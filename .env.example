# Public base URL of the deployed site. Used by metadataBase, sitemap, robots, and JSON-LD.
# Local: http://localhost:3000 (default). Production: set to the EXACT canonical host
# that wins the redirect (the apex 301/307s to www), so canonicals don't point at a
# URL that immediately redirects.
NEXT_PUBLIC_SITE_URL=https://www.anmolmalhan.com

# --- Contact form backend (optional) ---
# If unset, the contact form falls back to opening the user's default mail client (mailto).
# If set, the Server Action sends through Resend (https://resend.com).
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@anmolmalhan.com
CONTACT_FROM_EMAIL=portfolio@yourdomain.com
